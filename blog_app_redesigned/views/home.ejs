<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include("./partials/head") %>
  <title>Blogify — Share Ideas With The World</title>
</head>
<body>
  <%- include("./partials/nav") %>

  <section class="hero">
    <div class="hero-eyebrow">
      <i class="fa-solid fa-feather-pointed"></i>
      Stories Worth Reading
    </div>
    <h1>Where great <em>ideas</em><br>find their voice</h1>
    <div class="hero-divider"></div>
    <p>Discover thoughtful writing from creators around the world. Share your perspective, build your audience.</p>
    <% if(!locals.user){ %>
    <a href="/user/signup" class="btn btn-primary" style="font-size:1rem; padding: 13px 28px; border-radius: 50px;">
      Start Writing Free <i class="fa-solid fa-arrow-right"></i>
    </a>
    <% } else { %>
    <a href="/addBlog" class="btn btn-gold" style="font-size:1rem; padding: 13px 28px; border-radius: 50px;">
      <i class="fa-solid fa-pen-nib"></i> Write a Story
    </a>
    <% } %>
  </section>

  <div class="blog-grid">
    <% if(blogs.length === 0){ %>
    <div class="empty-state">
      <i class="fa-regular fa-newspaper"></i>
      <h3>No stories yet</h3>
      <p style="margin-top:6px;">Be the first to share something extraordinary.</p>
    </div>
    <% } %>
    <% blogs.forEach(blog => { %>
      <%- include("./partials/card", {blog}) %>
    <% }) %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
